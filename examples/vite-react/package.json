{
  "name": "vite-react",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@contentful/app-sdk": "4.51.4",
    "@contentful/f36-components": "5.9.0",
    "@contentful/f36-tokens": "5.1.0",
    "@contentful/react-apps-toolkit": "1.2.20",
    "contentful-management": "11.69.3",
    "@emotion/css": "11.13.5",
    "happy-dom": "^20.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:ci": "vitest run",
    "create-app-definition": "contentful-app-scripts create-app-definition",
    "add-locations": "contentful-app-scripts add-locations",
    "upload": "contentful-app-scripts upload --bundle-dir ./dist",
    "upload-ci": "contentful-app-scripts upload --ci --bundle-dir ./dist  --organization-id $CONTENTFUL_ORG_ID --definition-id $CONTENTFUL_APP_DEF_ID --token $CONTENTFUL_ACCESS_TOKEN",
    "lint": "eslint .",
    "lint:write": "eslint . --fix"
  },
  "devDependencies": {
    "@contentful/app-scripts": "^2.5.9",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.12",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.1.4",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
