{
  "functions": [
    {
      "id": "sfccApi",
      "name": "Salesforce Commerce Cloud API",
      "description": "Proxies SFCC product and category API calls server-side to avoid CORS restrictions.",
      "path": "functions/index.js",
      "entryFile": "functions/index.ts",
      "allowNetworks": [
        "*.demandware.com",
        "*.salesforce.com"
      ],
      "accepts": [
        "appaction.call"
      ]
    }
  ],
  "actions": [
    {
      "id": "sfccApi",
      "name": "SFCC API",
      "description": "Invokes the sfccApi function to proxy SFCC product and category API calls.",
      "type": "function-invocation",
      "functionId": "sfccApi",
      "category": "Custom",
      "parameters": [
        {
          "id": "type",
          "name": "Action Type",
          "type": "Symbol",
          "required": true
        },
        {
          "id": "query",
          "name": "Query",
          "type": "Symbol",
          "required": false
        },
        {
          "id": "productId",
          "name": "Product ID",
          "type": "Symbol",
          "required": false
        },
        {
          "id": "catalogId",
          "name": "Catalog ID",
          "type": "Symbol",
          "required": false
        },
        {
          "id": "categoryId",
          "name": "Category ID",
          "type": "Symbol",
          "required": false
        }
      ]
    }
  ]
}