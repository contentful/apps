{
  "name": "auto-prefix",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@contentful/app-sdk": "4.45.0",
    "@contentful/f36-components": "5.6.0",
    "@contentful/f36-tokens": "5.1.0",
    "@contentful/field-editor-single-line": "^1.9.0",
    "@contentful/node-apps-toolkit": "^3.15.0",
    "@contentful/react-apps-toolkit": "1.2.16",
    "@testing-library/jest-dom": "^6.9.1",
    "contentful-management": "11.62.0",
    "emotion": "10.0.17",
    "happy-dom": "^20.0.10",
    "prettier": "^3.6.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:ci": "vitest run",
    "create-app-definition": "contentful-app-scripts create-app-definition",
    "add-locations": "contentful-app-scripts add-locations",
    "upload": "contentful-app-scripts upload --bundle-dir ./build",
    "upload-ci": "contentful-app-scripts upload --ci --bundle-dir ./build  --organization-id $CONTENTFUL_ORG_ID --definition-id $CONTENTFUL_APP_DEF_ID --token $CONTENTFUL_ACCESS_TOKEN",
    "deploy": "contentful-app-scripts upload --ci --bundle-dir ./build --organization-id ${DEFINITIONS_ORG_ID} --definition-id 2W2ZZcwIMWRi8Enoqu7LBr --token ${CONTENTFUL_CMA_TOKEN}",
    "deploy:staging": "contentful-app-scripts upload --ci --bundle-dir ./build --organization-id ${TEST_ORG_ID} --definition-id 2W2ZZcwIMWRi8Enoqu7LBr --token ${TEST_CMA_TOKEN}",
    "lint": "eslint .",
    "lint:write": "eslint . --fix",
    "prettier:write": "prettier --write .",
    "prettier:check": "prettier --check .",
    "prettier:list": "prettier -l ."
  },
  "devDependencies": {
    "@contentful/app-scripts": "^2.5.6",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "24.10.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "5.1.0",
    "globals": "^16.5.0",
    "typescript": "5.9.3",
    "vite": "7.2.0",
    "vitest": "4.0.7"
  }
}
