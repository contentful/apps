# Copy to .env and fill in. Required for: npm run dev (ngrok + OAuth).

# ngrok – free at https://dashboard.ngrok.com/signup
# Get token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Atlassian OAuth – create app at https://developer.atlassian.com/console/myapps/
# Use callback URL: https://YOUR_NGROK_URL/test/auth (script prints the URL when you run dev)
ATLASSIAN_APP_CLIENT_ID=
ATLASSIAN_APP_CLIENT_SECRET=

# Optional: frontend port (default 1234)
# PORT=1234
