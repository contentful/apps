{
  "name": "contentful-link-checker",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "@tootallnate/once": ">=3.0.1",
    "tar": ">=7.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/relativize-html.js",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "create-app-definition": "contentful-app-scripts create-app-definition",
    "add-locations": "contentful-app-scripts add-locations",
    "build:functions": "contentful-app-scripts build-functions --ci",
    "build:all": "npm run build && npm run build:functions && node -e \"require('fs').mkdirSync('out/functions', {recursive: true}); require('fs').cpSync('build/functions', 'out/functions', {recursive: true})\"",
    "upload": "node scripts/upload-with-env.js",
    "upsert-actions": "node scripts/upsert-actions-with-env.js",
    "build-and-upload": "npm run build:all && npm run upload && npm run upsert-actions"
  },
  "dependencies": {
    "@contentful/app-sdk": "4.22.0",
    "@contentful/f36-components": "4.45.0",
    "@contentful/f36-multiselect": "^4.81.1",
    "@contentful/f36-tokens": "4.0.2",
    "@contentful/react-apps-toolkit": "1.2.16",
    "next": "15.5.12",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@contentful/app-scripts": "^2.5.9",
    "dotenv": "^17.2.2",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "14.0.0",
    "@types/node": "16.18.38",
    "@types/react": "18.2.14",
    "@types/react-dom": "18.2.6",
    "eslint": "8.44.0",
    "eslint-config-next": "13.4.8",
    "jest": "29.5.0",
    "jest-environment-jsdom": "29.5.0",
    "typescript": "5.1.6"
  }
}